# Work tooling auto-appends machine-specific sections to work.gitconfig (e.g.
# [trace2], [githooks]). The clean filter strips those before commits so only
# intentional config is tracked. The filter itself is registered in .git/config
# by ./dot install / ./dot sync — see setup/dotfiles/gitrepo.py for details.
config/git/global-config/work.gitconfig filter=strip-work-tooling
