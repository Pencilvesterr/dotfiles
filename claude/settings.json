{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "[ \"$(uname)\" = \"Darwin\" ] \u0026\u0026 osascript -e 'tell application \"System Events\" to set frontApp to name of first application process whose frontmost is true' -e 'if frontApp is not in {\"wezterm-gui\", \"idea\"} then display notification \"Claude needs your attention\" with title \"Claude Code\" sound name \"Glass\"' || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "[ \"$(uname)\" = \"Darwin\" ] && ~/.claude/hooks/aloc-managed/post_to_aloc.sh || true",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "[ \"$(uname)\" = \"Darwin\" ] && ~/.claude/hooks/aloc-managed/post_to_aloc.sh || true",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "[ \"$(uname)\" = \"Darwin\" ] \u0026\u0026 osascript -e 'tell application \"System Events\" to set frontApp to name of first application process whose frontmost is true' -e 'if frontApp is not in {\"wezterm-gui\", \"idea\"} then display notification \"Done — ready for your next message\" with title \"Claude Code\" sound name \"Glass\"' || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git reset --hard *)",
      "Bash(git checkout *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git rebase *)",
      "Bash(sudo *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)"
    ]
  },
  "statusLine": {
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "type": "command"
  },
  "theme": "dark"
}
