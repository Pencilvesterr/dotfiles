{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "medium",
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "[ \"$(uname)\" = \"Darwin\" ] \u0026\u0026 ~/.claude/hooks/aloc-managed/post_to_aloc.sh || true",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "/Users/mcrouch/.claude/hooks/aloc-managed/post_to_aloc.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "[ \"$(uname)\" = \"Darwin\" ] \u0026\u0026 ~/.claude/hooks/aloc-managed/post_to_aloc.sh || true",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "/Users/mcrouch/.claude/hooks/aloc-managed/post_to_aloc.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/notify.sh \"Done in %s — ready for your next message\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Read",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git reset --hard *)",
      "Bash(git checkout *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git rebase *)",
      "Bash(sudo *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)"
    ]
  },
  "statusLine": {
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "type": "command"
  },
  "theme": "dark"
}
