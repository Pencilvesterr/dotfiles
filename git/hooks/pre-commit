#!/bin/bash
# Self-heal dotfile links before committing (fix/adopt/conflict-abort) and pull
# app-managed files into the repo. Logic lives in install/dotfiles/hook.py.
# Skips silently on machines without a saved profile or without uv.
REPO_ROOT="$(git rev-parse --show-toplevel)"

if ! "$REPO_ROOT/dot" hook pre-commit; then
    # Distinguish a real conflict (dot ran and said abort) from tooling issues
    if command -v uv >/dev/null 2>&1 || [ -x "$HOME/.local/bin/uv" ]; then
        exit 1
    fi
    echo "==> uv not available; skipping dotfiles pre-commit checks"
fi
exit 0
